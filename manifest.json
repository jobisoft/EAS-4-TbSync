{
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "eas4tbsync@jobisoft.de",
      "strict_min_version": "140.0",
      "strict_max_version": "151.*"
    }
  },
  "name": "__MSG_extensionName__",
  "version": "5.0.3",
  "author": "John Bieling",
  "homepage_url": "https://github.com/jobisoft/EAS-4-TbSync",
  "default_locale": "en-US",
  "description": "__MSG_extensionDescription__",
  "icons": {
    "16": "icons/eas16.png",
    "32": "icons/eas32.png",
    "64": "icons/eas64.png"
  },
  "permissions": [
    "storage",
    "management",
    "addressBooks",
    "notifications",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "background": {
    "type": "module",
    "scripts": ["background.mjs"]
  },
  "options_ui": {
    "page": "dialogs/options/options.html",
    "open_in_tab": false
  },
  "web_accessible_resources": [
    "icons/eas16.png",
    "icons/eas32.png",
    "icons/eas64.png",
    "icons/365_16.png",
    "icons/365_32.png"
  ],
  "experiment_apis": {
    "LegacyPrefs": {
      "schema": "experiments/LegacyPrefs/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["LegacyPrefs"]],
        "script": "experiments/LegacyPrefs/implementation.js"
      }
    },
    "LegacyLoginManager": {
      "schema": "experiments/LegacyLoginManager/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["LegacyLoginManager"]],
        "script": "experiments/LegacyLoginManager/implementation.js"
      }
    },
    "LegacyAbProperties": {
      "schema": "experiments/LegacyAbProperties/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["LegacyAbProperties"]],
        "script": "experiments/LegacyAbProperties/implementation.js"
      }
    },
    "calendar_provider": {
      "schema": "experiments/calendar/schema/calendar-provider.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiments/calendar/parent/ext-calendar-provider.js",
        "events": ["startup"],
        "paths": [["calendar", "provider"]]
      }
    },
    "calendar_calendars": {
      "schema": "experiments/calendar/schema/calendar-calendars.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiments/calendar/parent/ext-calendar-calendars.js",
        "paths": [["calendar", "calendars"]]
      }
    },
    "calendar_items": {
      "schema": "experiments/calendar/schema/calendar-items.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiments/calendar/parent/ext-calendar-items.js",
        "paths": [["calendar", "items"]]
      }
    },
    "calendar_timezones": {
      "schema": "experiments/calendar/schema/calendar-timezones.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiments/calendar/parent/ext-calendar-timezones.js",
        "paths": [["calendar", "timezones"]]
      },
      "child": {
        "scopes": ["addon_child"],
        "script": "experiments/calendar/child/ext-calendar-timezones.js",
        "paths": [["calendar", "timezones"]]
      }
    }
  }
}
