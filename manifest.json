{
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "eas4tbsync@jobisoft.de",
      "strict_min_version": "140.0"
    }
  },
  "name": "__MSG_extensionName__",
  "version": "5.0",
  "author": "John Bieling",
  "homepage_url": "https://github.com/jobisoft/EAS-4-TbSync",
  "default_locale": "en-US",
  "description": "__MSG_extensionDescription__",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "64": "icons/icon-64.png"
  },
  "permissions": [
    "storage",
    "management",
    "addressBooks",
    "notifications",
    "tabs",
    "cookies",
    "<all_urls>"
  ],
  "background": {
    "type": "module",
    "scripts": [
      "background.mjs"
    ]
  },
  "web_accessible_resources": [
    "icons/icon-16.png",
    "icons/icon-32.png",
    "icons/icon-64.png"
  ],
  "experiment_apis": {
    "LegacyPrefs": {
      "schema": "experiments/LegacyPrefs/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["LegacyPrefs"]],
        "script": "experiments/LegacyPrefs/implementation.js"
      }
    },
    "LegacyLoginManager": {
      "schema": "experiments/LegacyLoginManager/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["LegacyLoginManager"]],
        "script": "experiments/LegacyLoginManager/implementation.js"
      }
    }
  }
}
